---
import { getLocalizedPath } from '../lib/i18n';
import { urlFor } from '../lib/sanity';
import type { BlogPost } from '../lib/sanity';
import type { Locale } from '../lib/i18n';

interface Props {
  post: BlogPost;
  locale: string;
}

const { post, locale } = Astro.props;
const loc = locale as Locale;

const dateStr = new Date(post.date).toLocaleDateString(locale === 'th' ? 'th-TH' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<a
  href={getLocalizedPath(`/blog/${post.slug.current}`, locale)}
  class="group block"
>
  <div class="relative overflow-hidden aspect-[16/10] bg-neutral-900 rounded-sm">
    {post.thumbnail ? (
      <img
        src={urlFor(post.thumbnail).width(800).auto('format').url()}
        alt={post.title[loc]}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        transition:name={`blog-thumb-${post.slug.current}`}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-neutral-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
        </svg>
      </div>
    )}
  </div>
  <div class="mt-3">
    <time class="text-xs text-neutral-500">{dateStr}</time>
    <h3 class="text-sm font-medium text-white group-hover:text-neutral-300 transition-colors mt-1">
      {post.title[loc]}
    </h3>
    {post.excerpt?.[loc] && (
      <p class="text-xs text-neutral-400 mt-1 line-clamp-2">
        {post.excerpt[loc]}
      </p>
    )}
    {post.tags && post.tags.length > 0 && (
      <div class="flex gap-2 mt-2">
        {post.tags.map((tag) => (
          <span class="text-[10px] text-neutral-500 bg-neutral-900 px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    )}
  </div>
</a>
