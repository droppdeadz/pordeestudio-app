---
import { getLocalizedPath } from '../lib/i18n';
import { urlFor } from '../lib/sanity';
import type { Project } from '../lib/sanity';
import type { Locale } from '../lib/i18n';

interface Props {
  project: Project;
  locale: string;
  size?: 'default' | 'small';
}

const { project, locale, size = 'default' } = Astro.props;
const loc = locale as Locale;
const imgWidth = size === 'small' ? 400 : 800;
---

<a
  href={getLocalizedPath(`/work/${project.slug.current}`, locale)}
  class="group block"
>
  <div class="relative overflow-hidden aspect-video bg-neutral-900 rounded-sm">
    {project.thumbnail ? (
      <img
        src={urlFor(project.thumbnail).width(imgWidth).auto('format').url()}
        alt={project.title[loc]}
        class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        loading="lazy"
        transition:name={`thumb-${project.slug.current}`}
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center text-neutral-600">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>
      </div>
    )}
    {project.duration && (
      <span class="absolute bottom-2 right-2 bg-black/70 text-white text-xs px-2 py-0.5 font-mono rounded-sm">
        {project.duration}
      </span>
    )}
  </div>
  <div class="mt-3">
    <h3 class="text-sm font-medium text-white group-hover:text-neutral-300 transition-colors">
      {project.title[loc]}
    </h3>
    {project.description?.[loc] && (
      <p class="text-xs text-neutral-400 mt-1 line-clamp-2">
        {project.description[loc]}
      </p>
    )}
  </div>
</a>
