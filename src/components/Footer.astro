---
import { getTranslations } from '../lib/i18n';
import SocialLinks from './SocialLinks.astro';
import type { SiteSettings } from '../lib/sanity';

interface Props {
  locale: string;
  settings: SiteSettings | null;
}

const { locale, settings } = Astro.props;
const t = getTranslations(locale);

const instagram = settings?.socialLinks?.instagram ?? 'https://instagram.com/pordee.studio.official';
const facebook = settings?.socialLinks?.facebook ?? 'https://facebook.com/pordee.studio.production';
const youtube = settings?.socialLinks?.youtube ?? 'https://youtube.com/channel/UCeJOi_0rOW1SNYY4bI0rZJQ';
---

<footer class="border-t border-neutral-900 px-6 py-16">
  <div class="max-w-6xl mx-auto">
    <p class="text-sm font-medium tracking-wider mb-2">"{t('site.tagline')}"</p>
    <p class="text-sm text-neutral-400 mb-8">{t('site.description')}</p>

    <div class="mb-8">
      <SocialLinks instagram={instagram} facebook={facebook} youtube={youtube} />
    </div>

    <p class="text-xs text-neutral-500">{t('footer.copyright')}</p>
  </div>
</footer>
