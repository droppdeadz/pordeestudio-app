---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { getTranslations, getLocalizedPath, locales, type Locale } from '../../lib/i18n';
import { getFeaturedProjects, getSiteSettings, urlFor } from '../../lib/sanity';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);

const [settings, featuredProjects] = await Promise.all([
  getSiteSettings(),
  getFeaturedProjects(),
]);

const heroSrc = settings?.aboutImage
  ? urlFor(settings.aboutImage).width(1920).auto('format').url()
  : null;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Pordee Studio',
  url: Astro.site?.toString() ?? '',
  description: t('site.description'),
  inLanguage: locale === 'th' ? 'th-TH' : 'en-US',
};
---

<BaseLayout locale={locale} title={`${t('site.title')} — ${t('site.tagline')}`} description={t('site.description')} ogImage={heroSrc ?? undefined} jsonLd={jsonLd}>
  {/* Hero Section */}
  {heroSrc ? (
    <section class="w-full">
      <div class="w-full aspect-video md:aspect-[21/9] overflow-hidden">
        <img
          src={heroSrc}
          alt={t('site.title')}
          class="w-full h-full object-cover"
        />
      </div>
    </section>
  ) : (
    <section class="w-full h-[60vh] bg-neutral-950" />
  )}

  {/* Featured Projects */}
  {featuredProjects.length > 0 && (
    <section class="px-6 pb-24 max-w-6xl mx-auto">
      <div class="flex items-center justify-between mb-10">
        <h2 class="text-lg font-light tracking-wider">
          {t('home.featuredWork')}
        </h2>
        <a
          href={getLocalizedPath('/work', locale)}
          class="text-sm text-neutral-400 hover:text-white transition-colors"
        >
          {t('home.viewAllWork')} &rarr;
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" data-animate-stagger>
        {featuredProjects.map((project) => (
          <div data-animate>
            <ProjectCard project={project} locale={locale} />
          </div>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
