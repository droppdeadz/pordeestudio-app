---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import YearFilter from '../../../components/YearFilter.astro';
import { getTranslations, locales, type Locale } from '../../../lib/i18n';
import { getProjects } from '../../../lib/sanity';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale } }));
}

const locale = Astro.params.locale as Locale;
const t = getTranslations(locale);
const projects = await getProjects();
const years = [...new Set(projects.map((p) => p.year))].sort((a, b) => b - a);
---

<BaseLayout locale={locale} title={`${t('work.title')} — ${t('site.title')}`}>
  <section class="px-6 py-16 max-w-6xl mx-auto">
    <h1 class="text-2xl font-light tracking-wider mb-10">
      {t('work.title')}
    </h1>

    {years.length > 1 && (
      <YearFilter years={years} locale={locale} />
    )}

    {projects.length > 0 ? (
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {projects.map((project) => (
          <div data-year={String(project.year)}>
            <ProjectCard project={project} locale={locale} />
          </div>
        ))}
      </div>
    ) : (
      <p class="text-neutral-400">{t('work.noProjects')}</p>
    )}
  </section>
</BaseLayout>
