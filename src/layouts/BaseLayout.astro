---
import '../styles/globals.css';
import { ClientRouter } from 'astro:transitions';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getTranslations } from '../lib/i18n';
import { getSiteSettings } from '../lib/sanity';
import type { SiteSettings } from '../lib/sanity';

interface Props {
  title?: string;
  description?: string;
  locale: string;
}

const { description = '', locale } = Astro.props;
const t = getTranslations(locale);
const title = Astro.props.title ?? t('site.title');
const settings = await getSiteSettings();
---

<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/logo.png" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Noto+Sans+Thai:wght@300;400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <ClientRouter />
  </head>
  <body class="bg-black text-white font-sans antialiased min-h-screen flex flex-col">
    <Header locale={locale} transition:animate="none" />
    <main class="flex-1" transition:animate="fade">
      <slot />
    </main>
    <Footer locale={locale} settings={settings} transition:animate="none" />
  </body>
</html>
